# Auth for Store API
STORE_JWT_SECRET=change-me
STORE_JWT_ALGORITHM=HS256
# Optional. Set if your JWT includes audience validation.
STORE_JWT_AUDIENCE=

# Order paid event protection (optional but recommended)
EVENT_WEBHOOK_SECRET=change-me

# Database: set DATABASE_URL for Postgres. If empty, SQLite fallback is used.
DATABASE_URL=

# SQLite fallback path
SUBSCRIPTIONS_DB_PATH=subscriptions.db

# Redis queue (required for app/worker split mode)
REDIS_URL=
ORDER_PAID_QUEUE_NAME=order_paid_events

# Marzban
MARZBAN_URL=http://localhost:8000
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=change-me
MARZBAN_TIMEOUT_MS=10000
MARZBAN_MAX_RETRIES=3
MARZBAN_DEFAULT_DATA_LIMIT_BYTES=429496729600

# Lemon Squeezy compatibility webhook
LEMONSQUEEZY_WEBHOOK_SECRET=change-me
PLAN_MONTHLY_VARIANT_ID=
PLAN_YEARLY_VARIANT_ID=